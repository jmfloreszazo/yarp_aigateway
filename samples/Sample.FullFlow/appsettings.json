{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information",
      "Gateway": "Information"
    }
  },
  "AllowedHosts": "*",

  "ReverseProxy": {
    "Routes": {

      "weather-api": {
        "ClusterId": "weather-service",
        "Match": {
          "Path": "/api/weather/{**remainder}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api" }
        ]
      },

      "catalog-api": {
        "ClusterId": "catalog-service",
        "Match": {
          "Path": "/api/catalog/{**remainder}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api" }
        ]
      },

      "ai-chat": {
        "ClusterId": "azure-openai",
        "Match": {
          "Path": "/ai/chat/completions",
          "Methods": [ "POST" ]
        },
        "Transforms": [
          { "PathSet": "/openai/deployments/gpt-5-chat/chat/completions" },
          { "QueryValueParameter": "api-version", "Set": "2025-01-01-preview" }
        ]
      }

    },
    "Clusters": {

      "weather-service": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5100/"
          }
        }
      },

      "catalog-service": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:5200/"
          }
        }
      },

      "azure-openai": {
        "Destinations": {
          "primary": {
            "Address": "https://testjmfzfoundryai.openai.azure.com/"
          }
        }
      }

    }
  }
}
