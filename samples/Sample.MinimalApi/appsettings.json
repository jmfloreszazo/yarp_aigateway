{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",

  "ReverseProxy": {
    "Routes": {
      "ai-chat": {
        "ClusterId": "azure-openai",
        "Match": {
          "Path": "/ai/chat/completions",
          "Methods": [ "POST" ]
        },
        "Transforms": [
          { "PathSet": "/openai/deployments/gpt-5-chat/chat/completions" },
          { "QueryValueParameter": "api-version", "Set": "2025-01-01-preview" }
        ]
      }
    },
    "Clusters": {
      "azure-openai": {
        "Destinations": {
          "primary": {
            "Address": "https://testjmfzfoundryai.openai.azure.com/"
          }
        }
      }
    }
  }
}
