{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",

  "ReverseProxy": {
    "Routes": {
      "openai-raw-proxy": {
        "ClusterId": "azure-openai-cluster",
        "Match": {
          "Path": "/proxy/openai/{**remainder}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/proxy/openai" }
        ]
      }
    },
    "Clusters": {
      "azure-openai-cluster": {
        "Destinations": {
          "primary": {
            "Address": "https://testjmfzfoundryai.openai.azure.com/"
          }
        }
      }
    }
  }
}
