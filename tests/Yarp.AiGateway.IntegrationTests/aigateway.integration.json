{
  "gateway": {
    "endpoint": "/ai/chat",
    "timeoutSeconds": 60
  },
  "providers": {
    "azure-openai": {
      "type": "azure-openai",
      "endpoint": "https://testjmfzfoundryai.openai.azure.com",
      "apiKey": "env:AZURE_OPENAI_API_KEY",
      "defaultModel": "gpt-5-chat",
      "enabled": true,
      "deploymentMap": {
        "gpt-5-chat": "gpt-5-chat"
      }
    }
  },
  "routing": {
    "defaultProvider": "azure-openai",
    "defaultModel": "gpt-5-chat",
    "rules": [
      {
        "name": "default-azure",
        "provider": "azure-openai",
        "model": "gpt-5-chat",
        "conditions": []
      }
    ],
    "fallbacks": []
  },
  "guardrails": {
    "input": [
      {
        "type": "max-length",
        "mode": "block",
        "parameters": {
          "maxLength": 32000
        }
      },
      {
        "type": "prompt-injection",
        "mode": "block",
        "parameters": {}
      },
      {
        "type": "pii",
        "mode": "sanitize",
        "parameters": {
          "detectEmails": true,
          "detectPhones": true,
          "detectCreditCards": true,
          "detectSsn": true,
          "detectIban": true,
          "detectSpanishDni": true
        }
      },
      {
        "type": "secret-detection",
        "mode": "block",
        "parameters": {}
      },
      {
        "type": "blocked-patterns",
        "mode": "block",
        "parameters": {
          "patterns": [
            "DROP TABLE",
            "DELETE FROM",
            "TRUNCATE TABLE",
            "INSERT INTO",
            "UNION SELECT",
            "xp_cmdshell",
            "EXEC xp_",
            "WAITFOR DELAY",
            "INTO OUTFILE",
            "<script>",
            "<iframe>",
            "javascript:",
            "onerror=",
            "eval(",
            "politics",
            "political party",
            "elections",
            "president",
            "congress",
            "football",
            "soccer",
            "FIFA",
            "Champions League",
            "World Cup"
          ]
        }
      }
    ],
    "output": [
      {
        "type": "blocked-patterns",
        "mode": "block",
        "parameters": {
          "patterns": [
            "internal server error",
            "stack trace:",
            "connection string",
            "password=",
            "api_key",
            "apikey",
            "secret_key",
            "access_token",
            "Authorization: Bearer",
            "BEGIN RSA PRIVATE KEY",
            "BEGIN PRIVATE KEY",
            "AccountKey=",
            "SharedAccessSignature=",
            "DefaultEndpointsProtocol=",
            "jdbc:",
            "mongodb://",
            "redis://",
            "amqp://",
            "sk-proj-"
          ]
        }
      },
      {
        "type": "pii",
        "mode": "sanitize",
        "parameters": {}
      }
    ]
  },
  "quotas": {
    "enabled": false,
    "rules": []
  },
  "telemetry": {
    "enabled": true,
    "logLevel": "Information",
    "emitMetrics": true,
    "emitTraces": true,
    "emitAuditEvents": true
  }
}
